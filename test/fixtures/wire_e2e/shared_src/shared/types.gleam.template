import gleam/dict.{type Dict}
import gleam/option.{type Option}

pub type Status {
  Pending
  Active
  Cancelled
}

pub type Item {
  Item(id: Int, name: String, price: Float, in_stock: Bool)
}

pub type Tree {
  Leaf
  Node(value: Int, left: Tree, right: Tree)
}

pub type ItemError {
  NotFound
  ValidationFailed(field: String, reason: String)
}

pub type WithFloats {
  WithFloats(x: Float, y: Float, label: String)
}

pub type NestedRecord {
  NestedRecord(
    items: List(Item),
    primary: Option(Item),
    statuses: List(Status),
    by_id: Dict(String, Item),
  )
}

/// Envelope wrapping a single list — the most common admin-page response shape.
/// Mirrors v3 patterns like DiscountAdminData(discounts: List(Discount)).
pub type ItemListData {
  ItemListData(items: List(Item))
}

/// Envelope with list + metadata — a paginated list response.
/// Mirrors patterns like accounting/payouts list pages.
pub type ItemSummaryData {
  ItemSummaryData(items: List(Item), total: Int, page: Int)
}

/// Form prefill response — record with optional pre-existing entity plus enum default.
/// Mirrors edit-page initial loads where the entity may or may not exist.
pub type FormPrefill {
  FormPrefill(item: Option(Item), default_status: Status)
}

/// Doubly-nested envelope — page-data wrapped inside another wrapper.
/// Mirrors patterns like ReportData(payload: ListData, message: Option(String)).
pub type NestedEnvelope {
  NestedEnvelope(data: ItemListData, message: Option(String))
}

/// Mixed dict-and-list envelope — both indexed lookup and ordered list.
/// Mirrors patterns where the same data is exposed two ways.
pub type DictAndListEnvelope {
  DictAndListEnvelope(by_id: Dict(String, Item), ordered: List(Item))
}

/// Same-name collision test: this `Tag` has 2 fields.
/// shared/collision.gleam defines another `Tag` with 1 field.
/// Both must coexist on the wire without collision.
pub type Tag {
  Tag(label: String, color: String)
}

