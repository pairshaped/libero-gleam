pub fn server_echo_panic(
  value _value: Int,
  server_context server_context: ServerContext,
) -> #(Result(Int, Nil), ServerContext) {
  // Deliberate runtime panic caught by trace.try_call in the generated
  // dispatch. The dispatch returns Error(InternalError(...)), and the
  // request_id round-trips.
  panic as "handler panic test"
}

