---
version: 2.0.0
title: tagged union typed decoder
file: ./test/libero/typed_decoder_codegen_test.gleam
test_name: tagged_union_snapshot_test
---
export function decode_shared_notification_notification(term) {
  const tag = Array.isArray(term) ? term[0] : term;
  switch (tag) {
    case "b010c12384": // ItemsLoaded @ shared/notification
      return new _m_shared_notification.ItemsLoaded(decode_list_of((t0) => decode_shared_item_item(t0), term[1]));
    case "326bdc0db9": // StatusChanged @ shared/notification
      return new _m_shared_notification.StatusChanged(decode_string(term[1]));
    case "affa55a329": // Disconnected @ shared/notification
      return new _m_shared_notification.Disconnected();
    case "113eb8ea33": // Refreshed @ shared/notification
      return new _m_shared_notification.Refreshed();
    default:
      throw new DecodeError("unknown variant atom: " + String(tag));
  }
}

registerAtomDecoder("b010c12384", "decode_shared_notification_notification", decode_shared_notification_notification);
registerAtomDecoder("326bdc0db9", "decode_shared_notification_notification", decode_shared_notification_notification);
registerAtomDecoder("affa55a329", "decode_shared_notification_notification", decode_shared_notification_notification);
registerAtomDecoder("113eb8ea33", "decode_shared_notification_notification", decode_shared_notification_notification);


export function ensure_decoders() { return true; }
