---
version: 2.0.0
title: record typed decoder
---
export function decode_shared_item_item(term) {
  if (!Array.isArray(term) || term[0] !== "a9192bf366") throw new DecodeError("expected a9192bf366 (Item @ shared/item), got " + (Array.isArray(term) ? String(term[0]) : typeof term));
  return new _m_shared_item.Item(
    decode_string(term[1]),
    decode_int(term[2]),
    decode_bool(term[3])
  );
}

registerAtomDecoder("a9192bf366", "decode_shared_item_item", decode_shared_item_item);


export function ensure_decoders() { return true; }
