title: record typed decoder
file: ./test/libero/typed_decoder_codegen_test.gleam
test_name: record_snapshot_test
---
export function decode_shared_item_item(term) {
  if (!Array.isArray(term) || term[0] !== "item") throw new DecodeError("expected item");
  return new _m_shared_item.Item(
    decode_string(term[1]),
    decode_int(term[2]),
    decode_bool(term[3])
  );
}

export function ensure_decoders() { return true; }
