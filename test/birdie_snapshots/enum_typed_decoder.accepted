---
version: 2.0.0
title: enum typed decoder
---
export function decode_shared_line_item_status(term) {
  if (term === "e50a687284") return new _m_shared_line_item.Pending(); // Pending @ shared/line_item
  if (term === "7664fc8036") return new _m_shared_line_item.Paid(); // Paid @ shared/line_item
  throw new DecodeError("unknown variant atom: " + String(term));
}

registerAtomDecoder("e50a687284", "decode_shared_line_item_status", decode_shared_line_item_status);
registerAtomDecoder("7664fc8036", "decode_shared_line_item_status", decode_shared_line_item_status);


export function ensure_decoders() { return true; }
